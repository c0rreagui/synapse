# ==============================
# SYNAPSE - DOCKERIGNORE (Lean Build Context)
# ==============================

# --- Dependencies (installed inside container) ---
.venv
backend/venv
frontend/node_modules
node_modules

# --- Build outputs ---
frontend/.next
frontend/out
frontend/storybook-static
__pycache__
*.pyc
*.pyo

# --- Git and IDE ---
.git
.gitignore
.github
.vscode
.idea

# --- Docker files (prevent recursive copy) ---
docker-compose*.yml
.dockerignore

# --- Database Volumes (CRITICAL: never copy to image) ---
backend/data/postgres
backend/data/redis
backend/data/minio

# --- Media and temp files ---
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.wav
*.mp3
*.log
*.png
*.jpg
*.jpeg
inputs/*
processing/*
done/*
errors/*
media/*

# --- Session Data (sensitive) ---
backend/data/sessions
backend/data/contexts

# --- Playwright cache (installed fresh in container) ---
ms-playwright

# --- Test artifacts ---
frontend/test-results
frontend/playwright-report
backend/tests/screenshots
backend/tests/test_videos

# --- Data volumes (mounted, not baked) ---
brain

# --- Debug scripts at root ---
debug_*.py
check_*.py
inspect_*.py
verify_*.py
*.bat
browser_test_log.txt
header_comparison.json
import_errors.txt
validator_debug.log
debug_upload_page.html

# --- Misc ---
*.db
*.sqlite
synapse.db*
MONITOR
auto-content-empire
tools
scripts/*.log
sonar-project.properties
pyrightconfig.json
TRELLO*.json
.env*
.pytest_cache
docs
